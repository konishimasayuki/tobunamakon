{
  "manifest_version": 3,
  "name": "東部生コン IME 自動切替",
  "version": "2.0.1",
  "description": "業務システムの入力欄で、業者名などは全角かな、日付や量などは半角英数へ IME を自動で切り替えます。Windows 常駐ホスト(tobu-ime-host.exe)と連携すると実際に切り替わります。未導入時はヒントのみ(ベストエフォート)。",
  "key": "",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tobunamakon.vercel.app/*",
        "https://*.tobunamakon.vercel.app/*",
        "http://localhost:5173/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
